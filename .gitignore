# ── Local server config ──────────────────────────────────────────────────────
/config.php
/roadmap.md

# ── Runtime data ─────────────────────────────────────────────────────────────
# Cache JSON files (login history, rate-limit counters). The folder .htaccess
# files are tracked — only the per-user runtime data is ignored.
/cache/login_history/*.json
/cache/rate_limit/*.json
/cache/shop/*.flag

# ── User-generated uploads ───────────────────────────────────────────────────
# Ticket attachments (kept private to the ticket owner + GMs at runtime,
# served via /ticket_attachment with auth checks). Folder .htaccess is
# tracked so the access-deny rule ships with the repo.
/uploads/tickets/*
# News post images (admin-uploaded via the news editor). Folder .htaccess is
# tracked so the override rule ships with the repo.
/uploads/news/*
!/uploads/news/.htaccess
# User avatars uploaded from the dashboard. Folder .htaccess is tracked so
# the public-read override ships with the repo.
/uploads/avatars/*
!/uploads/avatars/.htaccess
# Forum post images (admin- and user-uploaded via the forum composer).
# Folder .htaccess is tracked so the override rule ships with the repo.
/uploads/forum/*
!/uploads/forum/.htaccess

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Environment files (defensive — none used yet, but standard) ──────────────
.env
.env.local
.env.*.local

# ── IDE / editor settings ────────────────────────────────────────────────────
/.idea/
/.vscode/

# ── Editor swap / backup files ───────────────────────────────────────────────
*.swp
*.swo
*~
*.bak

# ── Node (in case JS tooling is ever added) ──────────────────────────────────
/node_modules/

# ── Composer local binary ────────────────────────────────────────────────────
/composer.phar

# ── OS clutter ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
