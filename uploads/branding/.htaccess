# Site branding (admin-uploaded logos, favicon, hero background) is public by
# design — it's referenced from every page's header and the homepage hero, so
# anonymous visitors must be able to load it. This file overrides the parent
# uploads/.htaccess (which denies everything) but still strips any executable
# extension as a belt-and-suspenders guard in case a bad file slipped past the
# upload endpoint's MIME check.

<RequireAll>
    Require all granted
</RequireAll>

# Even if Apache misroutes a request, never execute script files from here.
<FilesMatch "\.(php|phtml|phar|pl|py|cgi|sh|html?|svg)$">
    Require all denied
</FilesMatch>

Options -Indexes -ExecCGI
