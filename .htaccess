# Enable Rewrite Engine
RewriteEngine On

# Disable directory listings and MultiViews globally
Options -Indexes -MultiViews

# Custom error pages (routed through pages/ via the rewrite rules below)
ErrorDocument 404 /404

# --- Rules for Pretty URLs ---

# 1. Prevent rewriting for existing files and directories (assets, favicon, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2a. Armory profile: /armory/{character-name} → pages/armory.php?char={name}
#     [B] = URL-escape the backreference, so spaces/specials in the name don't
#     trip Apache 2.4's "rewritten query string contains control chars or
#     spaces" (AH10411) safety check. (WoW char names disallow spaces, but
#     defense-in-depth + consistency with the guild rule.)
RewriteRule ^armory/([^/]+)/?$ pages/armory.php?char=$1 [B,L,QSA]

# 2a-bis. Guild profile: /guild/{guild-name} → pages/guild.php?name={name}
#     Guild names CAN (and usually do) contain spaces, so [B] is required —
#     without it Apache returns 403 (AH10411) for any multi-word guild.
RewriteRule ^guild/([^/]+)/?$ pages/guild.php?name=$1 [B,L,QSA]

# 2b. Ticket detail (user side): /tickets/{id} → pages/ticket_view.php?id={id}
RewriteRule ^tickets/(\d+)/?$ pages/ticket_view.php?id=$1 [L,QSA]

# 2c. Ticket detail (admin side): /admin_ticket/{id} → pages/admin_ticket.php?id={id}
RewriteRule ^admin_ticket/(\d+)/?$ pages/admin_ticket.php?id=$1 [L,QSA]

# 2d. News post detail: /news/{slug} → pages/news.php?slug={slug}
RewriteRule ^news/([A-Za-z0-9_-]+)/?$ pages/news.php?slug=$1 [L,QSA]

# 2e. Forum routes. Order matters — the more-specific rules (with literal
#     "new", "edit", "reply" segments) come BEFORE the generic
#     /forum/{cat}/{thread} rule, so they take priority.
#
#     /forum/new/{cat}        → pages/forum_new_thread.php?cat={cat}
#     /forum/edit/{post_id}   → pages/forum_edit.php?id={id}
#     /forum/reply            → pages/forum_reply.php (POST)
#     /forum/{cat}/{thread}   → pages/forum.php?cat={cat}&thread={thread}
#     /forum/{cat}            → pages/forum.php?cat={cat}
RewriteRule ^forum/new/([A-Za-z0-9_-]+)/?$ pages/forum_new_thread.php?cat=$1 [L,QSA]
RewriteRule ^forum/edit/(\d+)/?$ pages/forum_edit.php?id=$1 [L,QSA]
RewriteRule ^forum/reply/?$ pages/forum_reply.php [L,QSA]
RewriteRule ^forum/mod/?$ pages/forum_mod.php [L,QSA]
RewriteRule ^forum/([A-Za-z0-9_-]+)/([A-Za-z0-9_-]+)/?$ pages/forum.php?cat=$1&thread=$2 [L,QSA]
RewriteRule ^forum/([A-Za-z0-9_-]+)/?$ pages/forum.php?cat=$1 [L,QSA]

# 2. Route /page → pages/page.php (pages/ directory)
RewriteCond %{DOCUMENT_ROOT}/pages/$1.php -f
RewriteRule ^([^/]+)/?$ pages/$1.php [L,QSA]

# 3. Fallback: Route /page → page.php in root (for index.php and any root-level files)
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^([^/]+)/?$ $1.php [L,QSA]

# --- Optional: Force HTTPS (Uncomment if needed) ---
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Optional: Force www or non-www (Uncomment ONE block if needed) ---
# Force non-www
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^(.*)$ http://%1/$1 [R=301,L]